    {
      "name": "GET lista de usuarios",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function() {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Data es un array\", function() {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.data).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Array tiene usuarios\", function() {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.data.length).to.be.greaterThan(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
